# ! NEVER COMMIT REAL API TOKENS IN THIS FILE
# INSTRUCTIONS: Copy to .env, fill in the values, and remove these top 2 lines.

# Optional labels for your own tooling / future wiring (not read by the app today)
SERVICE_NAME=backend
SERVICE_VERSION=0.1.0

NODE_ENV=development
PORT=3000
# Optional override; defaults to debug in development and info in production
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:3000

# Sentry - error tracking and performance monitoring
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=0.1.0
# Optional - defaults are 1 in development and 0.2 in production
SENTRY_TRACES_SAMPLE_RATE=1.0
# Set to true only if you intentionally want default PII (e.g. client IP) on events
SENTRY_SEND_DEFAULT_PII=false

# Grafana Cloud - log search and aggregation
LOKI_URL='' # Either on Grafana Cloud or self-hosted
LOKI_USERNAME='' # Grafana API token with Loki push permissions
LOKI_WRITE_API_KEY='' # Grafana API token with Loki push permissions
LOKI_SERVICE_NAME='backend' # The name of the service to log to Loki
LOKI_HEADERS='' # Optional - only if your Loki needs extra HTTP headers (e.g. self-hosted multi-tenant)
